# PostgreSQL
DATABASE_URL=postgresql://postgres:sifre@localhost:5432/yapi_stok

# JWT — ZORUNLU (yoksa uygulama başlamaz)
# Üretmek için: openssl rand -hex 32
SECRET_KEY=buraya-openssl-rand-hex-32-ciktisi-yazin

TOKEN_SURE_DK=1440

# CORS — virgülle ayrılmış origin listesi
# Geliştirme:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Üretim örneği:
# CORS_ORIGINS=https://app.foresto.example.com
